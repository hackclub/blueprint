<% content_for :head_assets do %>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" onload="typeof initGuildsMap === 'function' && initGuildsMap()"></script>
<% end %>

<section class="flex justify-center">
  <div class="w-full max-w-6xl space-y-4">

    <div class="py-4 md:py-8 text-center space-y-4">
      <h1 class="text-4xl md:text-6xl font-bold">Build Guilds!</h1>
      <p class="text-lg md:text-xl text-white/90 leading-relaxed max-w-2xl mx-auto">
        Hardware meetups happening in cities around the world.
        <br>Join an existing guild or start one in your city - <strong>April 13th-19th</strong>.
      </p>
      <div class="pt-2">
        <a href="#signup-form" class="inline-block bg-bp-warning hover:bg-bp-warning-darker text-white text-xl md:text-2xl font-semibold py-3 px-10 rounded-none transition-all duration-200 hover:scale-105 hover:shadow-lg hover:shadow-bp-warning/30">
          Join or start a guild
        </a>
      </div>
    </div>

    <div class="my-8 bg-bp-darker/50 p-6 rounded-none border-2 border-bp-darker">
      <div class="flex flex-col md:flex-row gap-6 items-stretch">
        <div class="bg-bp-dark p-8 rounded-none border border-white/25 w-full md:w-72 flex flex-col items-center justify-center text-center">
          <p class="text-5xl md:text-6xl font-bold text-white tabular-nums" id="total-signups">-</p>
          <p class="text-white/80 text-base uppercase tracking-wide mt-1">Signups</p>
          <div class="h-px bg-white/20 my-5 w-full"></div>
          <p class="text-5xl md:text-6xl font-bold text-white tabular-nums" id="total-guilds">-</p>
          <p class="text-white/80 text-base uppercase tracking-wide mt-1">Guilds</p>
        </div>

        <div id="guilds-map" class="w-full h-[28rem] md:h-[24rem] bg-bp-dark rounded-none border border-white/25 flex-1"></div>
      </div>
      <p class="text-xs text-white/50 mt-2 text-center">Click a guild on the map to join or view details!</p>
    </div>

    <script>
      function initGuildsMap() {
        const mapEl = document.getElementById('guilds-map');
        if (!mapEl || mapEl._leaflet_id || typeof L === 'undefined') return;

        const map = L.map('guilds-map', { scrollWheelZoom: true }).setView([20, 0], 2);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
        }).addTo(map);

        fetch('/guilds/map_data')
          .then(response => response.json())
          .then(guilds => {
            let totalSignups = 0;
            const bounds = [];

            guilds.forEach(g => {
              totalSignups += g.signup_count;
              if (g.lat && g.lng) {
                bounds.push([g.lat, g.lng]);
                const radius = Math.max(6, Math.min(20, 6 + g.signup_count * 1.5));
                const marker = L.circleMarker([g.lat, g.lng], {
                  radius: radius,
                  fillColor: "#f4c542",
                  color: "#fff",
                  weight: 1.5,
                  opacity: 1,
                  fillOpacity: 0.85
                }).addTo(map);
                var popupEl = document.createElement('div');
                popupEl.style.color = '#1a1a2e';
                var cityText = document.createTextNode(g.city);
                var b = document.createElement('b');
                b.appendChild(cityText);
                popupEl.appendChild(b);
                popupEl.appendChild(document.createElement('br'));
                popupEl.appendChild(document.createTextNode(g.signup_count + ' signup' + (g.signup_count === 1 ? '' : 's')));
                popupEl.appendChild(document.createElement('br'));
                var link = document.createElement('a');
                link.href = '#signup-form';
                link.style.cssText = 'color: #b8860b; font-weight: bold;';
                link.textContent = 'Join this guild';
                link.dataset.city = g.city;
                link.dataset.country = g.country || '';
                link.addEventListener('click', function(e) {
                  prefillGuild(this.dataset.city, this.dataset.country);
                });
                popupEl.appendChild(link);
                if (g.slack_channel_id) {
                  popupEl.appendChild(document.createElement('br'));
                  var slackLink = document.createElement('a');
                  slackLink.href = 'https://hackclub.slack.com/archives/' + g.slack_channel_id;
                  slackLink.target = '_blank';
                  slackLink.style.cssText = 'color: #888; font-size: 0.75em;';
                  slackLink.textContent = '(#build-guild-' + g.city.toLowerCase().replace(/\s+/g, '-') + ')';
                  popupEl.appendChild(slackLink);
                }
                marker.bindPopup(popupEl);
              }
            });

            // Keep default world view - don't auto-zoom to guilds

            animateCount('total-guilds', guilds.length);
            animateCount('total-signups', totalSignups);
          })
          .catch(err => console.error('Error loading map data:', err));

        function animateCount(id, target) {
          const el = document.getElementById(id);
          if (target === 0) { el.textContent = '0'; return; }
          const duration = 600;
          const start = performance.now();
          function step(now) {
            const progress = Math.min((now - start) / duration, 1);
            el.textContent = Math.round(progress * target);
            if (progress < 1) requestAnimationFrame(step);
          }
          requestAnimationFrame(step);
        }
      }

      document.addEventListener('turbo:load', initGuildsMap);
    </script>

    <%= render 'shared/card', class: 'flex flex-col space-y-4 border-2 border-bp-darker bg-bp-darker/50 p-6 rounded-none' do %>
      <h2 class="text-2xl md:text-3xl font-semibold text-white">Overview</h2>

      <p class="text-white/90 leading-relaxed">
        Build guilds are Hack Club hardware meetups happening <strong>April 13th-19th</strong> in cities around the world. Organizers and attendees have a lot of freedom with what they want to run. Some will have workshops, some project demos, some just building and hanging out together.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-bp-darker/50 rounded-none overflow-hidden">
          <figure>
            <%= image_tag "guilds/tavern-toronto.jpg", alt: "Hack Clubbers at Mystic Tavern Toronto", class: "w-full h-32 object-cover" %>
            <figcaption class="text-xs text-white/40 px-4 pt-1">Mystic Tavern (Toronto)</figcaption>
          </figure>
          <div class="p-4 pt-2">
            <h3 class="font-semibold text-bp-warning mb-1">Who?</h3>
            <p class="text-white/80 text-sm"><strong>Anyone</strong> from Hack Club can attend - no hardware experience needed. Organizers need an approved Blueprint project.</p>
          </div>
        </div>

        <div class="bg-bp-darker/50 rounded-none overflow-hidden">
          <figure>
            <%= image_tag "guilds/juice-shanghai.png", alt: "Hack Clubbers at Juice Shanghai", class: "w-full h-32 object-cover" %>
            <figcaption class="text-xs text-white/40 px-4 pt-1">Juice (Shanghai)</figcaption>
          </figure>
          <div class="p-4 pt-2">
            <h3 class="font-semibold text-bp-warning mb-1">Where?</h3>
            <p class="text-white/80 text-sm">Community spaces, makerspaces, schools - organizers pick a safe, hardware-friendly venue in their city.</p>
          </div>
        </div>

        <div class="bg-bp-darker/50 rounded-none overflow-hidden">
          <figure>
            <%= image_tag "guilds/shipwrecked.jpg", alt: "Hack Clubbers at Shipwrecked Boston", class: "w-full h-32 object-cover" %>
            <figcaption class="text-xs text-white/40 px-4 pt-1">Shipwrecked (Boston)</figcaption>
          </figure>
          <div class="p-4 pt-2">
            <h3 class="font-semibold text-bp-warning mb-1">How?</h3>
            <p class="text-white/80 text-sm">Sign up below as an organizer or attendee. Enter your city and we'll match you to an existing guild or create a new one. Alternatively, you can select a guild on the map.</p>
          </div>
        </div>
      </div>
    <% end %>

    <figure class="rounded-none overflow-hidden border-2 border-bp-darker">
      <%= image_tag "guilds/undercity.png", alt: "Hack Clubbers at Undercity", class: "w-full h-56 md:h-72 object-cover" %>
      <figcaption class="bg-bp-darker/50 px-4 py-2 text-sm text-white/60 text-center">
        Hack Clubbers at Undercity, a 72 hour hardware hackathon at GitHub HQ!
      </figcaption>
    </figure>

    <%= render 'shared/card', class: 'flex flex-col space-y-6 border-2 border-bp-darker bg-bp-darker/50 p-6 rounded-none' do %>
      <h2 class="text-2xl md:text-3xl font-semibold text-white">Information for Organizers</h2>

      <div class="space-y-4">
        <div class="space-y-2">
          <h3 class="text-xl font-semibold text-bp-warning">Who Can Organize a Guild?</h3>
          <p class="text-white/90 leading-relaxed">
            Anyone with an approved Blueprint project can organize a guild. There are no extra requirements –
            you don't have to be really good at coding or have organized events before, just be excited to run a meetup and be able to commit time to making it happen.
          </p>
        </div>

        <div class="space-y-2">
          <h3 class="text-xl font-semibold text-bp-warning">What Can You Run at a Guild?</h3>
          <p class="text-white/90 leading-relaxed">
            Guilds are very flexible! You can host workshops, show off projects, or run any wacky activities, provided they are safe and cost-effective. Here are some ideas:
          </p>
          <ul class="list-disc list-inside space-y-1 text-white/90">
            <li>Project build sessions!</li>
            <li>Lightning talks</li>
            <li>Soldering competitions</li>
            <li>Misc workshops!</li>
          </ul>
        </div>

        <div class="space-y-2">
          <h3 class="text-xl font-semibold text-bp-warning">What Do Organizers Do?</h3>
          <ul class="list-disc list-inside space-y-1 text-white/90">
            <li>Start your guild! Pick up a name for your guild.</li>
            <li>Choose a day between April 13th-19th to run your event!</li>
            <li>Find a venue! Make sure you have their permission to run any activities you're planning.</li>
            <li>Get signups! You'll get <strong>$10 per person</strong> who shows up to your event.</li>
            <li>Figure out logistics like food, activities, &amp; schedule.</li>
            <li>Run your event!</li>
          </ul>
        </div>
      </div>
    <% end %>

    <%= render 'shared/card', html_options: { id: 'signup-form' }, class: 'flex flex-col space-y-4 border-2 border-bp-darker bg-bp-darker/50 p-6 rounded-none' do %>
      <h2 class="text-2xl md:text-3xl font-semibold text-white text-center">Sign Up!</h2>

      <% if @signup.errors.any? %>
        <div class="bg-red-500/20 border border-red-500 rounded-none p-4 text-white mb-4 max-w-xl mx-auto">
          <h2 class="font-bold">Please fix the following errors:</h2>
          <ul class="list-disc list-inside">
            <% @signup.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @signup, url: guild_signups_path, local: true, class: "flex flex-col gap-4 max-w-xl w-full mx-auto", id: "guild-signup-form" do |f| %>
        <%= f.hidden_field :role, id: "role-field", value: @signup.role || "attendee" %>

        <div class="mb-2">
          <label class="block text-white font-medium mb-1">I want to join as:</label>
          <div class="flex gap-4">
            <button type="button" id="attendee-btn" class="btn flex-1 bg-bp-dark text-white border border-white/25 rounded-none py-3 transition-colors"
                    onclick="selectRole('attendee')">Attendee</button>
            <button type="button" id="organizer-btn" class="btn flex-1 bg-bp-dark text-white border border-white/25 rounded-none py-3 transition-colors"
                    onclick="selectRole('organizer')">Organizer</button>
          </div>
          <% if @signup.errors[:role].any? %>
            <p class="text-red-500 text-sm mt-1"><%= @signup.errors[:role].join(', ') %></p>
          <% end %>
        </div>

        <div>
          <label class="block text-white font-medium mb-1">Full Name</label>
          <%= f.text_field :name,
                placeholder: "e.g. Orpheus",
                class: "w-full p-3 bg-bp-dark border #{@signup.errors[:name].any? ? 'border-red-500' : 'border-white/25'} rounded-none text-white" %>
          <% if @signup.errors[:name].any? %>
            <p class="text-red-500 text-sm mt-1"><%= @signup.errors[:name].join(', ') %></p>
          <% end %>
        </div>

        <div>
          <label class="block text-white font-medium mb-1">Email address</label>
          <p class="text-sm text-white/60 mb-1">We'll use this to contact you about your guild.</p>
          <%= f.email_field :email,
                value: @signup.email.presence || current_user&.email,
                placeholder: "e.g. orpheus@hackclub.com",
                class: "w-full p-3 bg-bp-dark border #{@signup.errors[:email].any? ? 'border-red-500' : 'border-white/25'} rounded-none text-white" %>
          <% if @signup.errors[:email].any? %>
            <p class="text-red-500 text-sm mt-1"><%= @signup.errors[:email].join(', ') %></p>
          <% end %>
        </div>

        <div>
          <label class="block text-white font-medium mb-1">City / location</label>
          <p class="text-sm text-white/60 mb-1">Enter your full city name.</p>
          <%= text_field_tag 'guild_signup[city]', @city || params.dig(:guild_signup, :city),
                id: "guild-city-field",
                placeholder: "e.g. New York City, not NYC",
                class: "w-full p-3 bg-bp-dark border #{@signup.errors[:city].any? ? 'border-red-500' : 'border-white/25'} rounded-none text-white" %>
          <% if @signup.errors[:city].any? %>
            <p class="text-red-500 text-sm mt-1"><%= @signup.errors[:city].join(', ') %></p>
          <% end %>
        </div>

        <div data-controller="searchable-select">
          <label class="block text-white font-medium mb-1">Country</label>
          <%= f.select :country,
                options_for_select(country_options, @signup.country),
                { include_blank: "Choose a country" },
                id: "guild-country-field",
                class: "w-full p-3 bg-bp-dark border #{@signup.errors[:country].any? ? 'border-red-500' : 'border-white/25'} rounded-none text-white",
                data: { searchable_select_target: "select" } %>
          <% if @signup.errors[:country].any? %>
            <p class="text-red-500 text-sm mt-1"><%= @signup.errors[:country].join(', ') %></p>
          <% end %>
        </div>

        <div id="organizer-ideas-container" class="<%= 'hidden' unless @signup.organizer? %>">
          <label class="block text-white font-medium mb-1">What would you like to run?</label>
          <p class="text-sm text-white/60 mb-1">Tell us a bit about any ideas you have – this doesn't have to be final!</p>
          <%= f.text_area :ideas,
                value: @signup.ideas,
                rows: 4,
                placeholder: "e.g. soldering workshop, project demos, lightning talks etc",
                class: "w-full p-3 bg-bp-dark border #{@signup.errors[:ideas].any? ? 'border-red-500' : 'border-white/25'} rounded-none text-white" %>
          <% if @signup.errors[:ideas].any? %>
            <p class="text-red-500 text-sm mt-1"><%= @signup.errors[:ideas].join(', ') %></p>
          <% end %>
        </div>

        <div id="attendee-activities-container" class="<%= 'hidden' if @signup.organizer? %>">
          <label class="block text-white font-medium mb-1">What would you like to do at your guild? (Optional)</label>
          <%= f.text_area :attendee_activities,
                value: @signup.attendee_activities,
                rows: 3,
                placeholder: "e.g. learn to solder, show off my blueprint project, just hang out...",
                class: "w-full p-3 bg-bp-dark border #{@signup.errors[:attendee_activities].any? ? 'border-red-500' : 'border-white/25'} rounded-none text-white" %>
          <% if @signup.errors[:attendee_activities].any? %>
            <p class="text-red-500 text-sm mt-1"><%= @signup.errors[:attendee_activities].join(', ') %></p>
          <% end %>
        </div>

        <%= f.submit "Submit!",
              class: "btn bg-bp-warning text-white text-xl md:text-2xl border-0 w-full rounded-none hover:bg-bp-warning-darker cursor-pointer",
              data: { turbo_submits_with: "Submitting..." } %>
      <% end %>

      <p class="text-sm text-white/60 text-center">
        We'll be in touch soon!
      </p>

      <script>
        function selectRole(role) {
          document.getElementById('role-field').value = role;

          const attendeeBtn = document.getElementById('attendee-btn');
          const organizerBtn = document.getElementById('organizer-btn');
          const ideasContainer = document.getElementById('organizer-ideas-container');
          const activitiesContainer = document.getElementById('attendee-activities-container');

          if (role === 'organizer') {
            ideasContainer.classList.remove('hidden');
            activitiesContainer.classList.add('hidden');
            organizerBtn.classList.add('bg-bp-warning');
            attendeeBtn.classList.remove('bg-bp-warning');
          } else {
            ideasContainer.classList.add('hidden');
            activitiesContainer.classList.remove('hidden');
            attendeeBtn.classList.add('bg-bp-warning');
            organizerBtn.classList.remove('bg-bp-warning');
          }
        }

        selectRole(document.getElementById('role-field').value || 'attendee');

        function prefillGuild(city, country) {
          var cityField = document.getElementById('guild-city-field');
          var countryField = document.getElementById('guild-country-field');
          if (cityField) cityField.value = city;
          if (countryField && country) {
            var options = countryField.options;
            for (var i = 0; i < options.length; i++) {
              if (options[i].value.toLowerCase() === country.toLowerCase()) {
                countryField.value = options[i].value;
                var wrapper = countryField.closest('[data-controller="searchable-select"]');
                if (wrapper) {
                  var searchInput = wrapper.querySelector('input[type="text"]');
                  if (searchInput) searchInput.value = options[i].text;
                }
                break;
              }
            }
          }
          document.getElementById('signup-form').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      </script>
    <% end %>

    <% if @signup&.errors&.any? %>
      <script>
        document.addEventListener('turbo:load', function() {
          var form = document.getElementById('signup-form');
          if (form) form.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
      </script>
    <% end %>

  </div>
</section>
