<%= render 'shared/card', html_options: { id: 'signup-form' }, class: 'flex flex-col space-y-4 border-2 border-bp-darker bg-bp-darker/50 p-6 rounded-none' do %>
  <h2 class="text-2xl md:text-3xl font-semibold text-white text-center">Signups Are Closed</h2>
  <p class="text-white/90 leading-relaxed text-center max-w-2xl mx-auto">
    Build Guild signups are now closed. Thanks to everyone who signed up to organize or attend!
  </p>
  <p class="text-white/90 leading-relaxed text-center max-w-2xl mx-auto">
    Join the <a href="https://slack.hackclub.com/" target="_blank" rel="noopener noreferrer" class="text-bp-warning underline">Hack Club Slack</a> to find out about future programmes!
  </p>
<% end %>

<script>
  function prefillGuild(city, country) {
    var el = document.getElementById('signup-form');
    if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
</script>
