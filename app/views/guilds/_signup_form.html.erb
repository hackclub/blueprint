<%= render 'shared/card', html_options: { id: 'signup-form' }, class: 'flex flex-col space-y-4 border-2 border-bp-darker bg-bp-darker/50 p-6 rounded-none' do %>
  <h2 class="text-2xl md:text-3xl font-semibold text-white text-center"><%= user_logged_in? ? "Sign Up!" : "Sign Up to Attend!" %></h2>

  <% if @signup.errors.any? %>
    <div class="bg-red-500/20 border border-red-500 rounded-none p-4 text-white mb-4 max-w-xl mx-auto">
      <h2 class="font-bold">Please fix the following errors:</h2>
      <ul class="list-disc list-inside">
        <% @signup.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if !user_logged_in? && params[:otp_sent] %>
    <%= form_with url: guild_signups_verify_path, method: :post, local: true, class: "flex flex-col gap-4 max-w-xl w-full mx-auto" do |f| %>
      <%= f.text_field :otp, required: true, autofocus: true, autocomplete: "one-time-code", class: "w-full p-3 bg-bp-dark border border-white/25 rounded-none text-white placeholder-white/50 text-lg", placeholder: "Check your email for a code!" %>
      <button type="submit" class="btn bg-bp-warning text-white text-xl md:text-2xl border-0 w-full rounded-none hover:bg-bp-warning-darker cursor-pointer">
        Verify &amp; Sign Up
      </button>
    <% end %>

  <% elsif !user_logged_in? %>
    <%= form_with url: guild_signups_signup_path, method: :post, local: true, class: "flex flex-col gap-4 max-w-xl w-full mx-auto", id: "guild-signup-form" do |f| %>
      <%= f.hidden_field "guild_signup[role]", id: "role-field", value: "attendee" %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-white font-medium mb-1">Full Name</label>
          <%= f.text_field "guild_signup[name]", placeholder: "e.g. Orpheus", required: true,
                class: "w-full p-3 bg-bp-dark border border-white/25 rounded-none text-white" %>
        </div>

        <div>
          <label class="block text-white font-medium mb-1">Email address</label>
          <%= f.email_field "guild_signup[email]", placeholder: "e.g. orpheus@hackclub.com", required: true,
                class: "w-full p-3 bg-bp-dark border border-white/25 rounded-none text-white" %>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-white font-medium mb-1">City / location</label>
          <%= f.text_field "guild_signup[city]", id: "guild-city-field", placeholder: "e.g. New York City, not NYC", required: true,
                value: @city || params.dig(:guild_signup, :city),
                class: "w-full p-3 bg-bp-dark border border-white/25 rounded-none text-white" %>
        </div>

        <div data-controller="searchable-select">
          <label class="block text-white font-medium mb-1">Country</label>
          <%= f.select "guild_signup[country]",
                options_for_select(country_options, nil),
                { include_blank: "Choose a country" },
                id: "guild-country-field",
                class: "w-full p-3 bg-bp-dark border border-white/25 rounded-none text-white",
                data: { searchable_select_target: "select" } %>
        </div>
      </div>

      <div data-controller="age-warning">
        <label class="block text-white font-medium mb-1">When's your birthday?</label>
        <p class="text-white/60 text-xs text-left mb-2">Build Guilds are for teenagers aged 13-18.</p>
        <%= f.date_field "guild_signup[birthday]", required: true, class: "w-full p-3 bg-bp-dark border border-white/25 rounded-none text-white [color-scheme:dark]",
            data: { age_warning_target: "input", action: "change->age-warning#validate" } %>
        <p class="text-yellow-400 text-sm mt-1 hidden" data-age-warning-target="warning">
          Are you sure? This age seems unusual. Please double-check your birthday.
        </p>
      </div>

      <div>
        <label class="block text-white font-medium mb-1">What would you like to do at your guild? (Optional)</label>
        <%= f.text_area "guild_signup[attendee_activities]", rows: 3, placeholder: "e.g. learn to solder, show off my blueprint project, just hang out...",
              class: "w-full p-3 bg-bp-dark border border-white/25 rounded-none text-white" %>
      </div>

      <div style="position:absolute;left:-9999px;" aria-hidden="true">
        <%= f.text_field :website, tabindex: "-1", autocomplete: "off" %>
      </div>

      <button type="submit" class="btn bg-bp-warning text-white text-xl md:text-2xl border-0 w-full rounded-none hover:bg-bp-warning-darker cursor-pointer">
        Submit!
      </button>

      <div class="bg-bp-dark/50 border border-white/10 rounded-none p-4 text-center">
        <p class="text-white/80 text-sm font-medium">Want to organize a guild?</p>
        <p class="text-white/60 text-xs mt-1">You need an approved Blueprint project to organize a guild. <a href="<%= login_path %>" class="text-bp-warning underline hover:text-bp-warning-darker font-semibold">Log in or sign up</a> first.</p>
      </div>
    <% end %>

  <% else %>
    <%= form_with model: @signup, url: guild_signups_path, local: true, class: "flex flex-col gap-4 max-w-xl w-full mx-auto", id: "guild-signup-form" do |f| %>
      <%= f.hidden_field :role, id: "role-field", value: @signup.role || "attendee" %>

      <div class="mb-2">
        <label class="block text-white font-medium mb-1">I want to join as:</label>
        <div class="flex gap-4">
          <button type="button" id="attendee-btn" class="btn flex-1 bg-bp-dark text-white border border-white/25 rounded-none py-3 transition-colors"
                  onclick="selectRole('attendee')">Attendee</button>
          <button type="button" id="organizer-btn" class="btn flex-1 bg-bp-dark text-white border border-white/25 rounded-none py-3 transition-colors"
                  onclick="selectRole('organizer')">Organizer</button>
        </div>
        <% if @signup.errors[:role].any? %>
          <p class="text-red-500 text-sm mt-1"><%= @signup.errors[:role].join(', ') %></p>
        <% end %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-white font-medium mb-1">Full Name</label>
          <%= f.text_field :name,
                placeholder: "e.g. Orpheus",
                class: "w-full p-3 bg-bp-dark border #{@signup.errors[:name].any? ? 'border-red-500' : 'border-white/25'} rounded-none text-white" %>
          <% if @signup.errors[:name].any? %>
            <p class="text-red-500 text-sm mt-1"><%= @signup.errors[:name].join(', ') %></p>
          <% end %>
        </div>

        <div>
          <label class="block text-white font-medium mb-1">Email address</label>
          <%= f.email_field :email,
                value: @signup.email.presence || current_user&.email,
                placeholder: "e.g. orpheus@hackclub.com",
                class: "w-full p-3 bg-bp-dark border #{@signup.errors[:email].any? ? 'border-red-500' : 'border-white/25'} rounded-none text-white" %>
          <% if @signup.errors[:email].any? %>
            <p class="text-red-500 text-sm mt-1"><%= @signup.errors[:email].join(', ') %></p>
          <% end %>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-white font-medium mb-1">City / location</label>
          <%= text_field_tag 'guild_signup[city]', @city || params.dig(:guild_signup, :city),
                id: "guild-city-field",
                placeholder: "e.g. New York City, not NYC",
                class: "w-full p-3 bg-bp-dark border #{@signup.errors[:city].any? ? 'border-red-500' : 'border-white/25'} rounded-none text-white" %>
          <% if @signup.errors[:city].any? %>
            <p class="text-red-500 text-sm mt-1"><%= @signup.errors[:city].join(', ') %></p>
          <% end %>
        </div>

        <div data-controller="searchable-select">
          <label class="block text-white font-medium mb-1">Country</label>
          <%= f.select :country,
                options_for_select(country_options, @signup.country),
                { include_blank: "Choose a country" },
                id: "guild-country-field",
                class: "w-full p-3 bg-bp-dark border #{@signup.errors[:country].any? ? 'border-red-500' : 'border-white/25'} rounded-none text-white",
                data: { searchable_select_target: "select" } %>
          <% if @signup.errors[:country].any? %>
            <p class="text-red-500 text-sm mt-1"><%= @signup.errors[:country].join(', ') %></p>
          <% end %>
        </div>
      </div>

      <div id="organizer-ideas-container" class="<%= 'hidden' unless @signup.organizer? %>">
        <label class="block text-white font-medium mb-1">What would you like to run?</label>
        <p class="text-sm text-white/60 mb-1">Tell us a bit about any ideas you have – this doesn't have to be final!</p>
        <%= f.text_area :ideas,
              value: @signup.ideas,
              rows: 4,
              placeholder: "e.g. soldering workshop, project demos, lightning talks etc",
              class: "w-full p-3 bg-bp-dark border #{@signup.errors[:ideas].any? ? 'border-red-500' : 'border-white/25'} rounded-none text-white" %>
        <% if @signup.errors[:ideas].any? %>
          <p class="text-red-500 text-sm mt-1"><%= @signup.errors[:ideas].join(', ') %></p>
        <% end %>
      </div>

      <div id="attendee-activities-container" class="<%= 'hidden' if @signup.organizer? %>">
        <label class="block text-white font-medium mb-1">What would you like to do at your guild? (Optional)</label>
        <%= f.text_area :attendee_activities,
              value: @signup.attendee_activities,
              rows: 3,
              placeholder: "e.g. learn to solder, show off my blueprint project, just hang out...",
              class: "w-full p-3 bg-bp-dark border #{@signup.errors[:attendee_activities].any? ? 'border-red-500' : 'border-white/25'} rounded-none text-white" %>
        <% if @signup.errors[:attendee_activities].any? %>
          <p class="text-red-500 text-sm mt-1"><%= @signup.errors[:attendee_activities].join(', ') %></p>
        <% end %>
      </div>

      <div style="position:absolute;left:-9999px;" aria-hidden="true">
        <%= f.text_field :website, tabindex: "-1", autocomplete: "off" %>
      </div>

      <%= f.submit "Submit!",
            class: "btn bg-bp-warning text-white text-xl md:text-2xl border-0 w-full rounded-none hover:bg-bp-warning-darker cursor-pointer",
            data: { turbo_submits_with: "Submitting..." } %>
    <% end %>
  <% end %>

  <script>
    function selectRole(role) {
      document.getElementById('role-field').value = role;

      const attendeeBtn = document.getElementById('attendee-btn');
      const organizerBtn = document.getElementById('organizer-btn');
      const ideasContainer = document.getElementById('organizer-ideas-container');
      const activitiesContainer = document.getElementById('attendee-activities-container');

      if (role === 'organizer') {
        ideasContainer.classList.remove('hidden');
        activitiesContainer.classList.add('hidden');
        organizerBtn.classList.add('bg-bp-warning');
        attendeeBtn.classList.remove('bg-bp-warning');
      } else {
        ideasContainer.classList.add('hidden');
        activitiesContainer.classList.remove('hidden');
        attendeeBtn.classList.add('bg-bp-warning');
        organizerBtn.classList.remove('bg-bp-warning');
      }
    }

    var roleField = document.getElementById('role-field');
    if (roleField) selectRole(roleField.value || 'attendee');

    function prefillGuild(city, country) {
      var cityField = document.getElementById('guild-city-field');
      var countryField = document.getElementById('guild-country-field');
      if (cityField) cityField.value = city;
      if (countryField && country) {
        var options = countryField.options;
        for (var i = 0; i < options.length; i++) {
          if (options[i].value.toLowerCase() === country.toLowerCase()) {
            countryField.value = options[i].value;
            var wrapper = countryField.closest('[data-controller="searchable-select"]');
            if (wrapper) {
              var searchInput = wrapper.querySelector('input[type="text"]');
              if (searchInput) searchInput.value = options[i].text;
            }
            break;
          }
        }
      }
      document.getElementById('signup-form').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  </script>
<% end %>
