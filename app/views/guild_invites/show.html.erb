<% content_for :title, "Join the #{@guild.city} Build Guild - Blueprint" %>
<% content_for :description, "You're invited to join the #{@guild.city} Build Guild. Meet other teen hardware builders and work on projects together." %>

<section class="flex justify-center">
  <div class="w-full max-w-lg space-y-6 py-8">

    <%= render 'shared/card', class: 'flex flex-col space-y-6 border-2 border-bp-darker bg-bp-darker/50 p-8 rounded-none text-center' do %>
      <h1 class="text-3xl md:text-4xl font-bold text-white">You're Invited!</h1>

      <% country_name = ISO3166::Country[@guild.country]&.common_name || @guild.country %>
      <p class="text-lg text-white/90 leading-relaxed">
        You've been invited to join the
        <strong class="text-bp-warning"><%= @guild.city %> Build Guild</strong>
        in <strong><%= country_name %></strong>.
      </p>

      <% if @signup %>
        <div class="bg-green-500/20 border border-green-500 rounded-none p-4 text-white">
          You're already signed up for this guild as <strong><%= @signup.role %></strong>!
        </div>
        <a href="<%= guilds_path %>" class="inline-block bg-bp-warning hover:bg-bp-warning-darker text-white text-lg font-semibold py-3 px-8 rounded-none transition-all duration-200">
          View Guilds
        </a>

      <% elsif user_logged_in? %>
        <div class="bg-bp-dark/50 rounded-none p-4 text-left space-y-2 border border-white/10">
          <p class="text-white/80 text-sm">By joining, you'll be signed up as an <strong>attendee</strong>.</p>
          <ul class="text-white/70 text-sm space-y-1 list-disc list-inside">
            <li>Name: <strong><%= current_user.display_name %></strong></li>
            <li>Email: <strong><%= current_user.email %></strong></li>
          </ul>
        </div>

        <%= form_with url: accept_guild_invite_path(slug: params[:slug]), method: :post, data: { turbo: false } do |f| %>
          <div class="mb-4">
            <label for="name" class="block text-white font-medium mb-1 text-left">Your name</label>
            <%= f.text_field :name, value: current_user.display_name, required: true, class: "w-full input bg-bp-dark border border-white/25 text-white" %>
          </div>
          <% if current_user.birthday.nil? %>
            <div class="mb-4" data-controller="age-warning">
              <label for="birthday" class="block text-white font-medium mb-1 text-left">When's your birthday?</label>
              <p class="text-white/60 text-xs text-left mb-2">Build Guilds are for teenagers aged 13-18.</p>
              <%= f.date_field :birthday, required: true, class: "w-full input bg-bp-dark border border-white/25 text-white [color-scheme:dark]",
                  data: { age_warning_target: "input", action: "change->age-warning#validate" } %>
              <p class="text-yellow-400 text-sm mt-1 hidden" data-age-warning-target="warning">
                Are you sure? This age seems unusual. Please double-check your birthday.
              </p>
            </div>
          <% end %>
          <div style="position:absolute;left:-9999px;" aria-hidden="true">
            <%= f.text_field :website, tabindex: "-1", autocomplete: "off" %>
          </div>
          <button type="submit" class="w-full bg-bp-warning hover:bg-bp-warning-darker text-white text-xl md:text-2xl font-semibold py-4 px-8 rounded-none transition-all duration-200 hover:scale-105 hover:shadow-lg hover:shadow-bp-warning/30 cursor-pointer">
            Join <%= @guild.city %> Guild
          </button>
        <% end %>

      <% else %>
        <%# Logged-out: show inline signup %>
        <div class="bg-bp-dark/50 rounded-none p-4 text-left space-y-2 border border-white/10">
          <p class="text-white/80 text-sm">Sign up to join this guild as an <strong>attendee</strong>. We'll create an account for you automatically.</p>
          <p class="text-white/60 text-xs">Build Guilds are for teenagers aged 13-18.</p>
        </div>

        <% if params[:otp_sent] %>
          <%= form_with url: guild_invite_verify_path(slug: params[:slug]), method: :post, data: { turbo: false } do |f| %>
            <div class="flex flex-col space-y-4">
              <%= f.text_field :otp, required: true, autofocus: true, autocomplete: "one-time-code", class: "input placeholder-white/75 text-lg md:text-xl", placeholder: "Check your email for a code!" %>
              <button type="submit" class="w-full bg-bp-warning hover:bg-bp-warning-darker text-white text-xl md:text-2xl font-semibold py-4 px-8 rounded-none transition-all duration-200 hover:scale-105 hover:shadow-lg hover:shadow-bp-warning/30 cursor-pointer">
                Verify &amp; Join Guild
              </button>
            </div>
          <% end %>
        <% else %>
          <%= form_with url: guild_invite_signup_path(slug: params[:slug]), method: :post, data: { turbo: false } do |f| %>
            <div class="flex flex-col space-y-4">
              <%= f.text_field :name, required: true, class: "input placeholder-white/75 text-lg md:text-xl", placeholder: "Your name" %>
              <%= f.email_field :email, required: true, class: "input placeholder-white/75 text-lg md:text-xl", placeholder: "Your email" %>
              <div data-controller="age-warning">
                <label for="birthday" class="block text-white font-medium mb-1 text-left">When's your birthday?</label>
                <%= f.date_field :birthday, required: true, class: "w-full input bg-bp-dark border border-white/25 text-white [color-scheme:dark]",
                    data: { age_warning_target: "input", action: "change->age-warning#validate" } %>
                <p class="text-yellow-400 text-sm mt-1 hidden" data-age-warning-target="warning">
                  Are you sure? This age seems unusual. Please double-check your birthday.
                </p>
              </div>
              <div style="position:absolute;left:-9999px;" aria-hidden="true">
                <%= f.text_field :website, tabindex: "-1", autocomplete: "off" %>
              </div>
              <button type="submit" class="w-full bg-bp-warning hover:bg-bp-warning-darker text-white text-xl md:text-2xl font-semibold py-4 px-8 rounded-none transition-all duration-200 hover:scale-105 hover:shadow-lg hover:shadow-bp-warning/30 cursor-pointer">
                Sign up &amp; Join Guild
              </button>
            </div>
          <% end %>

          <div class="w-full flex items-center before:p-[1px] before:mr-2 before:bg-white/30 before:grow after:p-[1px] after:ml-2 after:bg-white/30 after:grow text-white/50 uppercase text-sm">or</div>

          <%= render "shared/button", url: hca_login_path(redirect_to: guild_invite_path(slug: params[:slug])), text: "Log in with Hack Club Auth", class: "text-lg w-full", html_options: { data: { turbo: false } } %>
        <% end %>
      <% end %>

      <p class="text-white/40 text-xs">
        Not the right guild? <a href="<%= guilds_path %>" class="underline hover:text-white/60">Browse all guilds</a>
      </p>
    <% end %>

  </div>
</section>
