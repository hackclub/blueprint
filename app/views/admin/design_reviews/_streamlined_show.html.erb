<%# Streamlined design reviewer UI — supports light/dark via data-sr-theme %>
<%# Flipper flag: streamlined_review_ui (per-user) %>

<style>
  /* Escape admin layout padding and remove browser focus outlines */
  .sr-fullscreen { margin: -2rem; }
  .sr-fullscreen details summary { outline: none; }
  .sr-fullscreen details summary::-webkit-details-marker { display: none; }
  /* Compact journal markdown — light defaults, dark overrides */
  .sr-journal { font-size: 0.7rem; line-height: 1.55; color: #52525b; }
  .sr-journal h1, .sr-journal h2, .sr-journal h3, .sr-journal h4 { font-family: inherit; color: #18181b; font-weight: 600; margin-top: 0.75rem; margin-bottom: 0.2rem; }
  .sr-journal h1 { font-size: 0.875rem; }
  .sr-journal h2 { font-size: 0.8125rem; }
  .sr-journal h3, .sr-journal h4 { font-size: 0.75rem; }
  .sr-journal p { margin-bottom: 0.4rem; }
  .sr-journal ul, .sr-journal ol { padding-left: 1.1rem; margin-bottom: 0.4rem; }
  .sr-journal li { margin-bottom: 0.1rem; }
  .sr-journal strong { color: #18181b; font-weight: 600; }
  .sr-journal code { font-family: monospace; font-size: 0.65rem; background: #f4f4f5; padding: 0.1rem 0.2rem; border-radius: 0.2rem; color: #52525b; }
  .sr-journal pre { background: #f4f4f5; padding: 0.5rem; border-radius: 0.375rem; overflow-x: auto; font-size: 0.65rem; margin-bottom: 0.4rem; }
  .sr-journal pre code { background: none; padding: 0; }
  .sr-journal blockquote { border-left: 2px solid #d4d4d8; padding-left: 0.6rem; color: #71717a; margin-bottom: 0.4rem; }
  .sr-journal a { color: #2563eb; }
  .sr-journal a:hover { color: #1d4ed8; }
  .sr-journal hr { border-color: #e4e4e7; margin: 0.5rem 0; }
  .sr-journal img { max-width: 100%; border-radius: 0.2rem; }
  /* Dark overrides for journal */
  [data-sr-theme=dark] .sr-journal { color: #a1a1aa; }
  [data-sr-theme=dark] .sr-journal h1,[data-sr-theme=dark] .sr-journal h2,[data-sr-theme=dark] .sr-journal h3,[data-sr-theme=dark] .sr-journal h4 { color: #d4d4d8; }
  [data-sr-theme=dark] .sr-journal strong { color: #d4d4d8; }
  [data-sr-theme=dark] .sr-journal code { background: #27272a; color: #a1a1aa; }
  [data-sr-theme=dark] .sr-journal pre { background: #18181b; }
  [data-sr-theme=dark] .sr-journal blockquote { border-color: #3f3f46; color: #71717a; }
  [data-sr-theme=dark] .sr-journal a { color: #60a5fa; }
  [data-sr-theme=dark] .sr-journal a:hover { color: #93c5fd; }
  [data-sr-theme=dark] .sr-journal hr { border-color: #27272a; }
</style>

<div class="sr-fullscreen flex flex-col bg-white text-zinc-900 dark:bg-zinc-950 dark:text-zinc-50"
     style="height: 100vh; overflow: hidden;"
     data-controller="review-keys"
     data-sr-theme="<%= cookies[:sr_theme].presence || "dark" %>"
     data-review-keys-repo-url-value="<%= project.repo_link %>"
     data-review-keys-slack-url-value="<%= project.design_slack_message %>">

  <%# ─── Sticky Navbar ─────────────────────────────────────────────── %>
  <nav class="flex items-center justify-between px-4 py-2 bg-zinc-100 border-b border-zinc-200 shrink-0 gap-4 dark:bg-zinc-900 dark:border-zinc-800">
    <div class="flex items-center gap-2">
      <%= link_to "End Session", admin_design_reviews_path,
            class: "px-3 py-1.5 rounded text-sm font-medium bg-zinc-200 hover:bg-zinc-300 text-zinc-700 border border-zinc-300 transition-colors dark:bg-zinc-800 dark:hover:bg-zinc-700 dark:text-zinc-300 dark:border-zinc-700" %>
      <%= link_to "Skip", admin_next_design_review_path(after: project.id, ysws_type: params[:ysws_type]),
            class: "px-3 py-1.5 rounded text-sm font-medium hover:bg-zinc-100 text-zinc-500 hover:text-zinc-800 transition-colors dark:hover:bg-zinc-800 dark:text-zinc-400 dark:hover:text-zinc-200" %>
    </div>

    <div class="flex-1 text-center">
      <%= link_to "#{project.title} (##{project.id})", project_path(project),
            target: "_blank",
            class: "text-sm font-medium text-zinc-800 hover:text-blue-600 transition-colors dark:text-zinc-200 dark:hover:text-blue-400" %>
    </div>

    <div class="flex items-center gap-2">
      <%= link_to "See User", admin_user_path(project.user),
            target: "_blank",
            class: "px-3 py-1.5 rounded text-sm font-medium hover:bg-zinc-100 text-zinc-600 hover:text-zinc-800 border border-zinc-300 transition-colors dark:hover:bg-zinc-800 dark:text-zinc-400 dark:hover:text-zinc-200 dark:border-zinc-700" %>
      <%= link_to "HCB",
            "https://hcb.hackclub.com/ysws-blueprint/card_grants/card_overview?q=#{ERB::Util.url_encode(project.user.email)}&event_id=ysws-blueprint",
            target: "_blank",
            class: "px-3 py-1.5 rounded text-sm font-medium hover:bg-zinc-100 text-zinc-600 hover:text-zinc-800 border border-zinc-300 transition-colors dark:hover:bg-zinc-800 dark:text-zinc-400 dark:hover:text-zinc-200 dark:border-zinc-700" %>
      <% if project.design_slack_message.present? %>
        <%= link_to project.design_slack_message, target: "_blank",
              class: "px-3 py-1.5 rounded text-sm font-medium hover:bg-zinc-100 text-zinc-600 hover:text-zinc-800 border border-zinc-300 transition-colors flex items-center gap-1 dark:hover:bg-zinc-800 dark:text-zinc-400 dark:hover:text-zinc-200 dark:border-zinc-700" do %>
          Slack <kbd class="text-xs font-mono px-1 py-px rounded border border-zinc-300 bg-zinc-100 text-zinc-500 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-500">s</kbd>
        <% end %>
      <% end %>
      <% if project.repo_link.present? %>
        <%= link_to project.repo_link, target: "_blank",
              class: "px-3 py-1.5 rounded text-sm font-medium hover:bg-zinc-100 text-zinc-600 hover:text-zinc-800 border border-zinc-300 transition-colors flex items-center gap-1 dark:hover:bg-zinc-800 dark:text-zinc-400 dark:hover:text-zinc-200 dark:border-zinc-700" do %>
          Repo <kbd class="text-xs font-mono px-1 py-px rounded border border-zinc-300 bg-zinc-100 text-zinc-500 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-500">r</kbd>
        <% end %>
      <% end %>
    </div>
  </nav>

  <%# ─── Two-column body ───────────────────────────────────────────── %>
  <div class="flex flex-1 min-h-0 lg:flex-row flex-col">

    <%# ── Left column: project info ─────────────────────────────────── %>
    <div class="flex-1 flex flex-col border-r border-zinc-200 dark:border-zinc-800 min-h-0">
      <div class="flex-1 overflow-y-auto p-4 space-y-3">

        <%# Hackpad warning %>
        <% if project.ysws == "hackpad" %>
          <% other_hackpads = project.user.projects.active.where(ysws: "hackpad", review_status: nil).where.not(id: project.id) %>
          <% if other_hackpads.any? %>
            <div class="rounded-md border border-amber-300 bg-amber-50/80 px-3 py-2 text-sm dark:border-amber-800 dark:bg-amber-950/30">
              <p class="font-medium text-amber-700 dark:text-amber-400">&#9888; This user has <%= pluralize(other_hackpads.count, "other hackpad") %> in review</p>
              <ul class="mt-1 space-y-0.5 text-amber-600/80 text-xs dark:text-amber-500/80">
                <% other_hackpads.each do |p| %>
                  <li><%= link_to p.title, admin_project_path(p), class: "hover:text-amber-700 underline dark:hover:text-amber-300" %> &mdash; created <%= p.created_at.strftime("%b %d, %Y") %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
        <% end %>

        <%# Claimed by other — full-width banner %>
        <% if claimed_by_other %>
          <div class="rounded-md border border-amber-300 bg-amber-50 px-4 py-3 dark:border-amber-800 dark:bg-amber-950/50">
            <div class="flex items-center justify-between gap-3 flex-wrap">
              <div>
                <p class="text-sm font-medium text-amber-700 dark:text-amber-400">
                  &#9888; Claimed by <%= project.design_review_claimed_by.display_name %>
                </p>
                <p class="text-xs text-amber-600/80 mt-0.5 dark:text-amber-500/80">
                  Lock expires ~<%= distance_of_time_in_words(project.design_review_claimed_at + 20.minutes, Time.current) %>. The review form is disabled.
                </p>
              </div>
              <%= link_to "Skip to Next", admin_next_design_review_path(after: project.id),
                    class: "shrink-0 text-xs px-2.5 py-1.5 rounded bg-amber-100 hover:bg-amber-200 text-amber-700 border border-amber-300 transition-colors dark:bg-amber-900/40 dark:hover:bg-amber-900/70 dark:text-amber-300 dark:border-amber-700" %>
            </div>
          </div>
        <% end %>

        <%# Project overview card %>
        <div class="rounded-md border border-zinc-200 bg-white overflow-hidden dark:border-zinc-800 dark:bg-zinc-900">
          <div class="flex">
            <%# Left: info %>
            <div class="flex-1 flex flex-col divide-y divide-zinc-200 dark:divide-zinc-800 min-w-0">
              <%# Title + description %>
              <div class="p-3 space-y-1" data-controller="text-expander">
                <h1 class="text-base font-semibold text-zinc-900 leading-snug dark:text-zinc-100">
                  <%= link_to project.title, admin_project_path(project), class: "hover:text-blue-600 transition-colors dark:hover:text-blue-400" %>
                </h1>
                <% if project.description.present? %>
                  <div class="relative">
                    <p class="text-sm text-zinc-600 leading-relaxed overflow-hidden dark:text-zinc-400"
                       style="max-height: 4.5rem"
                       data-text-expander-target="content">
                      <%= project.description %>
                    </p>
                    <button class="text-xs text-blue-600 hover:text-blue-700 mt-0.5 dark:text-blue-400 dark:hover:text-blue-300"
                            data-text-expander-target="toggle"
                            data-action="click->text-expander#toggle">
                      more
                    </button>
                  </div>
                <% end %>
                <p class="text-xs text-zinc-600 dark:text-zinc-400">
                  By <img src="<%= project.user.avatar_url %>" alt="" class="inline-block size-4 rounded-sm align-middle mr-0.5">
                  <span class="text-zinc-700 dark:text-zinc-300"><%= project.user.display_name %></span>
                  &middot; <%= project.created_at.strftime("%b %d, %Y") %>
                  <% if project.ysws.present? %>
                    &middot; <span class="text-zinc-700 dark:text-zinc-300"><%= project.ysws %></span>
                  <% end %>
                  <% if project.ysws == "hackpad" && project.approx_hour.present? %>
                    &middot; Self-reported: <span class="text-zinc-700 dark:text-zinc-300"><%= project.approx_hour %>h</span>
                  <% end %>
                </p>
              </div>

              <%# Stats row: tier | funding | hours %>
              <% total_hours = (project.journal_entries.sum(:duration_seconds) / 3600.0).round(1) %>
              <div class="grid grid-cols-3 divide-x divide-zinc-200 dark:divide-zinc-800">
                <div class="px-3 py-2">
                  <p class="text-xs text-zinc-600 mb-0.5 dark:text-zinc-400">Tier</p>
                  <% if project.tier.present? %>
                    <% tier_color = case project.tier.to_s
                      when "1" then "bg-red-50 text-red-600 border-red-300 dark:bg-red-950 dark:text-red-400 dark:border-red-800"
                      when "2" then "bg-orange-50 text-orange-600 border-orange-300 dark:bg-orange-950 dark:text-orange-400 dark:border-orange-800"
                      when "3" then "bg-yellow-50 text-yellow-600 border-yellow-300 dark:bg-yellow-950 dark:text-yellow-400 dark:border-yellow-800"
                      when "4" then "bg-lime-50 text-lime-600 border-lime-300 dark:bg-lime-950 dark:text-lime-400 dark:border-lime-800"
                      when "5" then "bg-emerald-50 text-emerald-700 border-emerald-300 dark:bg-emerald-950 dark:text-emerald-400 dark:border-emerald-800"
                      else "bg-zinc-100 text-zinc-600 border-zinc-300 dark:bg-zinc-800 dark:text-zinc-400 dark:border-zinc-700"
                      end %>
                    <span class="text-xs px-1.5 py-0.5 rounded border font-mono <%= tier_color %>">T<%= project.tier %></span>
                  <% else %>
                    <span class="text-sm text-zinc-500">—</span>
                  <% end %>
                </div>
                <div class="px-3 py-2">
                  <p class="text-xs text-zinc-600 mb-0.5 dark:text-zinc-400">Requesting</p>
                  <p class="text-sm text-zinc-800 font-mono dark:text-zinc-200">$<%= sprintf("%.2f", project.funding_needed_cents / 100.0) %></p>
                </div>
                <div class="px-3 py-2">
                  <p class="text-xs text-zinc-600 mb-0.5 dark:text-zinc-400">Hours</p>
                  <p class="text-sm text-zinc-800 font-mono dark:text-zinc-200"><%= total_hours %>h</p>
                </div>
              </div>

              <%# Links row %>
              <% link_count = [project.repo_link.present?, project.demo_link.present?].count(true) %>
              <% if link_count > 0 %>
                <div class="grid divide-x divide-zinc-200 dark:divide-zinc-800 <%= link_count == 2 ? 'grid-cols-2' : 'grid-cols-1' %>">
                  <% if project.repo_link.present? %>
                    <div class="px-3 py-2">
                      <p class="text-xs text-zinc-600 mb-0.5 dark:text-zinc-400">Repository</p>
                      <%= link_to project.repo_link, project.repo_link, target: "_blank",
                            class: "text-xs text-blue-600 hover:text-blue-700 truncate block transition-colors dark:text-blue-400 dark:hover:text-blue-300" %>
                    </div>
                  <% end %>
                  <% if project.demo_link.present? %>
                    <div class="px-3 py-2">
                      <p class="text-xs text-zinc-600 mb-0.5 dark:text-zinc-400">Demo</p>
                      <%= link_to project.demo_link, project.demo_link, target: "_blank",
                            class: "text-xs text-blue-600 hover:text-blue-700 truncate block transition-colors dark:text-blue-400 dark:hover:text-blue-300" %>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>

            <%# Right: banner image %>
            <% if project.display_banner %>
              <div class="w-64 shrink-0 border-l border-zinc-200 bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-950"
                   style="background-image: url('<%= url_for(project.display_banner) %>'); background-size: contain; background-repeat: no-repeat; background-position: center;">
              </div>
            <% end %>
          </div>
        </div>

        <%# Previous Reviews (collapsible) %>
        <% reviews = project.design_reviews.order(created_at: :desc) %>
        <% if reviews.any? %>
          <details class="group rounded-md border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900" data-review-keys-target="reviewsDetails">
            <summary class="flex items-center justify-between px-3 py-2 cursor-pointer hover:bg-zinc-50 rounded-md transition-colors list-none dark:hover:bg-zinc-800">
              <span class="flex items-center gap-1.5 flex-wrap">
                <span class="text-sm text-zinc-700 font-medium dark:text-zinc-300">Previous Reviews (<%= reviews.count %>)</span>
                <span class="text-xs text-zinc-400 dark:text-zinc-600">|</span>
                <% reviews.first(10).each do |r| %>
                  <% label = case r.result
                      when "approved" then "Approve"
                      when "returned" then "Return"
                      when "rejected" then "Deny"
                      else r.result&.capitalize
                      end
                     label = "A #{label}" if r.admin_review?
                     color_cls = case r.result
                       when "approved" then "bg-emerald-50 text-emerald-700 border-emerald-300 dark:bg-emerald-950 dark:text-emerald-400 dark:border-emerald-800"
                       when "returned" then "bg-amber-50 text-amber-700 border-amber-300 dark:bg-amber-950 dark:text-amber-400 dark:border-amber-800"
                       when "rejected" then "bg-red-50 text-red-600 border-red-300 dark:bg-red-950 dark:text-red-400 dark:border-red-800"
                       else "bg-zinc-100 text-zinc-600 border-zinc-300 dark:bg-zinc-800 dark:text-zinc-400 dark:border-zinc-700"
                       end
                     border_style = r.invalidated? ? "border-dashed" : "" %>
                  <span class="text-xs px-1.5 py-0.5 rounded border <%= color_cls %> <%= border_style %>"><%= label %></span>
                <% end %>
                <% if reviews.count > 10 %>
                  <span class="text-xs text-zinc-400 dark:text-zinc-600">...</span>
                <% end %>
              </span>
              <span class="flex items-center gap-1 shrink-0">
                <kbd class="text-xs font-mono px-1 py-px rounded border border-zinc-300 bg-zinc-100 text-zinc-400 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-600">w</kbd>
                <span class="text-zinc-500 group-open:rotate-90 transition-transform text-xs">&#9654;</span>
              </span>
            </summary>
            <div class="border-t border-zinc-200 divide-y divide-zinc-200 dark:border-zinc-800 dark:divide-zinc-800">
              <% reviews.each do |review| %>
                <div class="px-3 py-2.5 space-y-2">
                  <%# Header %>
                  <div class="flex items-center justify-between gap-2 flex-wrap">
                    <div class="flex items-center gap-1.5 flex-wrap">
                      <% row_color = case review.result
                           when "approved" then "bg-emerald-50 text-emerald-700 border-emerald-300 dark:bg-emerald-950 dark:text-emerald-400 dark:border-emerald-800"
                           when "returned" then "bg-amber-50 text-amber-700 border-amber-300 dark:bg-amber-950 dark:text-amber-400 dark:border-amber-800"
                           when "rejected" then "bg-red-50 text-red-600 border-red-300 dark:bg-red-950 dark:text-red-400 dark:border-red-800"
                           else "bg-zinc-100 text-zinc-600 border-zinc-300 dark:bg-zinc-800 dark:text-zinc-400 dark:border-zinc-700"
                           end
                         row_label = case review.result
                           when "approved" then "Approved"
                           when "returned" then "Return"
                           when "rejected" then "Rejected"
                           else review.result&.capitalize
                           end
                         row_border = review.invalidated? ? "border-dashed" : "" %>
                        <span class="text-xs px-1.5 py-0.5 rounded border <%= row_color %> <%= row_border %>"><%= row_label %></span>
                      <% if review.admin_review? %>
                        <span class="text-xs px-1.5 py-0.5 rounded bg-zinc-100 text-amber-600 border border-zinc-300 dark:bg-zinc-800 dark:text-amber-500 dark:border-zinc-700">Admin</span>
                      <% end %>
                      <% reviewer = User.find(review.reviewer_id) %>
                      <img src="<%= reviewer.avatar_url %>" alt="" class="inline-block size-4 rounded-sm align-middle">
                      <span class="text-xs text-zinc-700 dark:text-zinc-300"><%= reviewer.display_name %></span>
                    </div>
                    <span class="text-xs text-zinc-500 shrink-0"><%= review.created_at.strftime("%b %-d, %-I:%M %p") %></span>
                  </div>

                  <%# Reason %>
                  <% if review.reason.present? %>
                    <div data-controller="text-expander">
                      <p class="text-xs text-zinc-600 mb-0.5 dark:text-zinc-400">Reason</p>
                      <p class="text-sm text-zinc-700 leading-relaxed overflow-hidden dark:text-zinc-300"
                         style="max-height: 3rem"
                         data-text-expander-target="content"><%= review.reason %></p>
                      <button class="text-xs text-blue-600 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300"
                              data-text-expander-target="toggle"
                              data-action="click->text-expander#toggle">more</button>
                    </div>
                  <% end %>

                  <%# Feedback %>
                  <% if review.feedback.present? %>
                    <div data-controller="text-expander">
                      <p class="text-xs text-zinc-600 mb-0.5 dark:text-zinc-400">Feedback</p>
                      <p class="text-sm text-zinc-700 leading-relaxed overflow-hidden dark:text-zinc-300"
                         style="max-height: 3rem"
                         data-text-expander-target="content"><%= review.feedback %></p>
                      <button class="text-xs text-blue-600 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300"
                              data-text-expander-target="toggle"
                              data-action="click->text-expander#toggle">more</button>
                    </div>
                  <% end %>

                  <%# Overrides %>
                  <% overrides = [] %>
                  <% overrides << "Grant: $#{sprintf("%.2f", review.grant_override_cents / 100.0)}" if review.grant_override_cents.present? %>
                  <% overrides << "Hours: #{review.hours_override}" if review.hours_override.present? %>
                  <% overrides << "Tier: T#{review.tier_override}" if review.tier_override.present? %>
                  <% if overrides.any? %>
                    <p class="text-xs text-zinc-600 dark:text-zinc-400"><%= overrides.join(" | ") %></p>
                  <% end %>

                  <%# Frozen data %>
                  <% frozen = [] %>
                  <% frozen << "Funding: $#{sprintf("%.2f", review.frozen_funding_needed_cents / 100.0)}" if review.frozen_funding_needed_cents.present? %>
                  <% frozen << "Tier: #{review.frozen_tier}" if review.frozen_tier.present? %>
                  <% frozen << "Hours: #{(review.frozen_duration_seconds / 3600.0).round(2)}h" if review.frozen_duration_seconds.present? %>
                  <% frozen << "Entries: #{review.frozen_entry_count}" if review.frozen_entry_count.present? %>
                  <% if frozen.any? %>
                    <p class="text-xs text-zinc-500"><%= frozen.join(" | ") %></p>
                  <% end %>

                  <%# Note to reviewer %>
                  <% if review.frozen_reviewer_note.present? %>
                    <details class="text-xs">
                      <summary class="text-zinc-500 cursor-pointer hover:text-zinc-700 transition-colors dark:hover:text-zinc-300">Note to reviewer</summary>
                      <p class="mt-1 text-zinc-600 leading-relaxed dark:text-zinc-400"><%= review.frozen_reviewer_note %></p>
                    </details>
                  <% end %>
                </div>
              <% end %>
            </div>
          </details>
        <% end %>

        <%# Note from Author %>
        <% if project.reviewer_note.present? %>
          <div class="rounded-md border border-zinc-200 bg-white p-3 dark:border-zinc-800 dark:bg-zinc-900" data-controller="text-expander">
            <p class="text-xs uppercase tracking-widest text-zinc-500 font-medium mb-2">Note from Author</p>
            <div class="relative">
              <p class="text-sm text-zinc-700 leading-relaxed overflow-hidden dark:text-zinc-300"
                 style="max-height: 4.5rem"
                 data-text-expander-target="content">
                <%= project.reviewer_note %>
              </p>
              <button class="text-xs text-blue-600 hover:text-blue-700 mt-0.5 dark:text-blue-400 dark:hover:text-blue-300"
                      data-text-expander-target="toggle"
                      data-action="click->text-expander#toggle">
                more
              </button>
            </div>
          </div>
        <% end %>

        <%# Journal (all entries) %>
        <% all_entries = project.journal_entries
           entry_count = all_entries.count
           total_h = (all_entries.sum(:duration_seconds) / 3600.0).round(2)
           avg_h = entry_count > 0 ? (all_entries.average(:duration_seconds).to_f / 3600.0).round(2) : 0
           max_h = entry_count > 0 ? (all_entries.maximum(:duration_seconds).to_f / 3600.0).round(2) : 0
           min_h = entry_count > 0 ? (all_entries.minimum(:duration_seconds).to_f / 3600.0).round(2) : 0 %>
        <details class="group rounded-md border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900" data-review-keys-target="journalDetails">
          <summary class="flex items-center justify-between px-3 py-2 cursor-pointer hover:bg-zinc-50 rounded-md transition-colors list-none dark:hover:bg-zinc-800">
            <span class="text-sm text-zinc-700 dark:text-zinc-300">
              Journal
              <span class="text-zinc-500 font-normal">
                &nbsp;|&nbsp;Count: <%= entry_count %>
                &nbsp;|&nbsp;Total: <%= total_h %>h
                <% if entry_count > 0 %>
                  &nbsp;|&nbsp;Avg: <%= avg_h %>h
                  &nbsp;|&nbsp;Range: <%= min_h %>h&nbsp;&ndash;&nbsp;<%= max_h %>h
                <% end %>
              </span>
            </span>
            <span class="flex items-center gap-1 shrink-0">
              <kbd class="text-xs font-mono px-1 py-px rounded border border-zinc-300 bg-zinc-100 text-zinc-400 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-600">o</kbd>
              <span class="text-zinc-500 group-open:rotate-90 transition-transform text-xs">&#9654;</span>
            </span>
          </summary>
          <div class="border-t border-zinc-200 p-3 dark:border-zinc-800">
            <div class="sr-journal">
              <% base_url = Rails.application.routes.default_url_options[:host] || "localhost:3000" %>
              <%= sanitize_marksmith_html(Marksmith::Renderer.new(body: project.generate_journal(true), base_url: "http://#{base_url}").render) %>
            </div>
          </div>
        </details>

        <%# Cart Screenshots %>
        <details class="group rounded-md border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900" data-review-keys-target="screenshotsDetails">
          <summary class="flex items-center justify-between px-3 py-2 cursor-pointer hover:bg-zinc-50 rounded-md transition-colors list-none dark:hover:bg-zinc-800">
            <span class="text-sm text-zinc-700 dark:text-zinc-300">
              Cart Screenshots
              <span class="text-zinc-500">&nbsp;|&nbsp;Requesting: $<%= sprintf("%.2f", project.funding_needed_cents / 100.0) %></span>
            </span>
            <span class="flex items-center gap-1 shrink-0">
              <kbd class="text-xs font-mono px-1 py-px rounded border border-zinc-300 bg-zinc-100 text-zinc-400 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-600">c</kbd>
              <span class="text-zinc-500 group-open:rotate-90 transition-transform text-xs">&#9654;</span>
            </span>
          </summary>
          <div class="border-t border-zinc-200 p-3 dark:border-zinc-800">
            <% if project.cart_screenshots.attached? %>
              <div class="grid grid-cols-2 gap-3">
                <% project.cart_screenshots.each do |screenshot| %>
                  <%= link_to rails_blob_path(screenshot, disposition: "inline"), target: "_blank", rel: "noopener noreferrer" do %>
                    <%= image_tag screenshot,
                          class: "w-full rounded border border-zinc-200 object-contain bg-zinc-50 cursor-pointer hover:opacity-80 transition-opacity dark:border-zinc-800 dark:bg-zinc-950" %>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              <p class="text-sm text-zinc-600 dark:text-zinc-400">No screenshots uploaded.</p>
            <% end %>
          </div>
        </details>

      </div>

      <%# Theme toggle — sticky bottom left %>
      <div class="shrink-0 px-4 py-2 border-t border-zinc-200 dark:border-zinc-800">
        <button data-action="click->review-keys#toggleTheme"
                class="flex items-center gap-1 text-xs text-zinc-500 hover:text-zinc-700 transition-colors dark:hover:text-zinc-300">
          <span class="dark:hidden">🌙 Dark</span>
          <span class="hidden dark:inline">☀ Light</span>
        </button>
      </div>
    </div>

    <%# ── Right column: actions ─────────────────────────────────────── %>
    <div class="lg:w-80 shrink-0 overflow-y-auto border-t lg:border-t-0 lg:border-l border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-950">

      <%# User notes %>
      <div class="p-2 border-b border-zinc-200 dark:border-zinc-800">
        <p class="text-xs uppercase tracking-widest text-zinc-500 font-medium mb-1.5">User Notes</p>
        <%= turbo_frame_tag "user_notes_#{project.user.id}" do %>
          <%= form_with model: project.user, url: update_internal_notes_admin_user_path(project.user), method: :patch, html: { class: "space-y-1.5" } do |f| %>
            <%= f.hidden_field :frozen_internal_notes, value: project.user.internal_notes %>
            <%= f.hidden_field :streamlined, value: "1" %>
            <%= f.text_area :internal_notes,
                  rows: 2,
                  placeholder: "Internal notes about this user...",
                  value: project.user.internal_notes,
                  class: "w-full bg-white border border-zinc-300 rounded px-2 py-1.5 text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-1 focus:ring-zinc-300 resize-y dark:bg-zinc-900 dark:border-zinc-700 dark:text-zinc-100 dark:placeholder-zinc-500 dark:focus:ring-zinc-600" %>
            <%= f.submit "Save",
                  class: "px-2 py-1 rounded text-xs font-medium bg-zinc-100 hover:bg-zinc-200 text-zinc-600 border border-zinc-300 transition-colors cursor-pointer dark:bg-zinc-800 dark:hover:bg-zinc-700 dark:text-zinc-400 dark:border-zinc-700" %>
          <% end %>
        <% end %>
      </div>

      <%# Review form %>
      <div class="p-2">
        <p class="text-xs uppercase tracking-widest text-zinc-500 font-medium mb-2">Submit Design Review</p>
        <fieldset <%= "disabled" if claimed_by_other %> class="space-y-2">
          <%= form_with model: design_review,
                url: admin_design_review_create_path(project),
                method: :post,
                html: { class: "space-y-2" } do |f| %>
            <%= hidden_field_tag :ysws_type, params[:ysws_type] if params[:ysws_type].present? %>

            <%# Overrides: Hours + Grant | Tier + Guide %>
            <div class="grid grid-cols-2 gap-2">
              <div>
                <label class="block text-xs text-zinc-600 mb-1 dark:text-zinc-400">Hours Override</label>
                <%= f.number_field :hours_override,
                      step: 0.01,
                      placeholder: "#{total_hours}h",
                      class: "w-full bg-white border border-zinc-300 rounded px-2 py-1.5 text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-1 focus:ring-zinc-300 dark:bg-zinc-900 dark:border-zinc-700 dark:text-zinc-100 dark:placeholder-zinc-600 dark:focus:ring-zinc-600" %>
              </div>
              <div>
                <label class="block text-xs text-zinc-600 mb-1 dark:text-zinc-400">Grant Override <span class="text-zinc-500">(¢)</span></label>
                <%= f.number_field :grant_override_cents,
                      placeholder: project.funding_needed_cents.to_s,
                      class: "w-full bg-white border border-zinc-300 rounded px-2 py-1.5 text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-1 focus:ring-zinc-300 dark:bg-zinc-900 dark:border-zinc-700 dark:text-zinc-100 dark:placeholder-zinc-600 dark:focus:ring-zinc-600" %>
              </div>
              <div>
                <label class="block text-xs text-zinc-600 mb-1 dark:text-zinc-400">Tier Override</label>
                <%= f.select :tier_override,
                      Project.tier_options,
                      { include_blank: "T#{project.tier} (default)" },
                      class: "w-full bg-white border border-zinc-300 rounded px-2 py-1.5 text-sm text-zinc-900 focus:outline-none focus:ring-1 focus:ring-zinc-300 dark:bg-zinc-900 dark:border-zinc-700 dark:text-zinc-100 dark:focus:ring-zinc-600" %>
              </div>
              <div>
                <label class="block text-xs text-zinc-600 mb-1 dark:text-zinc-400">Guide Override</label>
                <% if current_user.admin? %>
                  <%= f.select :ysws,
                        Project.guide_options,
                        { selected: project.ysws || "none", include_blank: false },
                        class: "w-full bg-white border border-zinc-300 rounded px-2 py-1.5 text-sm text-zinc-900 focus:outline-none focus:ring-1 focus:ring-zinc-300 dark:bg-zinc-900 dark:border-zinc-700 dark:text-zinc-100 dark:focus:ring-zinc-600" %>
                <% else %>
                  <p class="text-xs text-zinc-500 pt-1">Admin only</p>
                <% end %>
              </div>
            </div>

            <%# Internal reason %>
            <div>
              <label class="block text-xs text-zinc-600 mb-1 dark:text-zinc-400">
                Justification (Internal) <kbd class="font-mono px-1 py-px rounded border border-zinc-300 bg-zinc-100 text-zinc-400 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-600" style="font-size:0.6rem">⌘J</kbd>
              </label>
              <%= f.text_area :reason,
                    rows: 3,
                    placeholder: "Justify your decision",
                    data: { "review-keys-target": "justification" },
                    class: "w-full bg-white border border-zinc-300 rounded px-2 py-1.5 text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-1 focus:ring-zinc-300 resize-y dark:bg-zinc-900 dark:border-zinc-700 dark:text-zinc-100 dark:placeholder-zinc-600 dark:focus:ring-zinc-600" %>
            </div>

            <%# Feedback (mandatory) %>
            <div>
              <label class="block text-xs text-zinc-600 mb-1 dark:text-zinc-400">
                Feedback <span class="text-red-500">*</span>
                <span class="text-zinc-500">(shown to user)</span>
                <kbd class="font-mono px-1 py-px rounded border border-zinc-300 bg-zinc-100 text-zinc-400 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-600" style="font-size:0.6rem">⌘F</kbd>
              </label>
              <%= f.text_area :feedback,
                    rows: 3,
                    placeholder: "Give feedback for the author",
                    required: true,
                    data: { "review-keys-target": "feedback" },
                    class: "w-full bg-white border border-zinc-300 rounded px-2 py-1.5 text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-1 focus:ring-zinc-300 resize-y dark:bg-zinc-900 dark:border-zinc-700 dark:text-zinc-100 dark:placeholder-zinc-600 dark:focus:ring-zinc-600" %>
            </div>

            <%# Action buttons %>
            <div class="grid grid-cols-2 gap-2 pt-1">
              <%= f.button type: "submit",
                    name: "design_review[result]",
                    value: "approved",
                    class: "px-3 py-2 rounded text-sm font-medium bg-emerald-50 hover:bg-emerald-100 text-emerald-700 border border-emerald-300 transition-colors flex items-center justify-center gap-1.5 dark:bg-emerald-900 dark:hover:bg-emerald-800 dark:text-emerald-100 dark:border-emerald-700",
                    data: { "review-keys-target": "approveBtn", "review-keys-action": "approve", action: "click->review-keys#buttonClicked" } do %>
                <span data-review-keys-target="approveLabelSpan">Approve</span>
                <kbd class="text-xs font-mono px-1 py-px rounded border border-emerald-300 bg-emerald-100 text-emerald-500 dark:border-emerald-700/40 dark:bg-black/20 dark:text-emerald-400/60">⌘P</kbd>
              <% end %>
              <%= f.button type: "submit",
                    name: "design_review[result]",
                    value: "returned",
                    class: "px-3 py-2 rounded text-sm font-medium bg-amber-50 hover:bg-amber-100 text-amber-700 border border-amber-300 transition-colors flex items-center justify-center gap-1.5 dark:bg-amber-900 dark:hover:bg-amber-800 dark:text-amber-100 dark:border-amber-700",
                    data: { "review-keys-target": "returnBtn" } do %>
                Return
                <kbd class="text-xs font-mono px-1 py-px rounded border border-amber-300 bg-amber-100 text-amber-500 dark:border-amber-700/40 dark:bg-black/20 dark:text-amber-400/60">⌘E</kbd>
              <% end %>
              <%= f.button type: "submit",
                    name: "design_review[result]",
                    value: "rejected",
                    class: "px-3 py-2 rounded text-sm font-medium bg-red-50 hover:bg-red-100 text-red-600 border border-red-300 transition-colors flex items-center justify-center gap-1.5 dark:bg-red-900 dark:hover:bg-red-800 dark:text-red-100 dark:border-red-700",
                    data: { "review-keys-target": "rejectBtn", "review-keys-action": "reject", action: "click->review-keys#buttonClicked" } do %>
                <span data-review-keys-target="rejectLabelSpan">Perm Reject</span>
                <kbd class="text-xs font-mono px-1 py-px rounded border border-red-300 bg-red-100 text-red-400 dark:border-red-700/40 dark:bg-black/20 dark:text-red-400/60">⌘K</kbd>
              <% end %>
              <%= link_to admin_next_design_review_path(after: project.id, ysws_type: params[:ysws_type]),
                    class: "px-3 py-2 rounded text-sm font-medium text-center bg-zinc-100 hover:bg-zinc-200 text-zinc-700 border border-zinc-300 transition-colors flex items-center justify-center gap-1.5 dark:bg-zinc-800 dark:hover:bg-zinc-700 dark:text-zinc-300 dark:border-zinc-700",
                    data: { "review-keys-target": "skipBtn" } do %>
                Skip
                <kbd class="text-xs font-mono px-1 py-px rounded border border-zinc-300 bg-zinc-100/20 text-zinc-500 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-500">⌘S</kbd>
              <% end %>
            </div>

            <%# Move to Build Review (admin only) %>
            <% if current_user.admin? %>
              <div class="pt-1 border-t border-zinc-200 dark:border-zinc-800">
                <%= button_to "Move to Build Review",
                      switch_review_phase_admin_project_path(project),
                      method: :post,
                      class: "w-full px-3 py-1.5 rounded text-xs font-medium text-zinc-600 hover:bg-zinc-100 border border-zinc-300 transition-colors dark:text-zinc-500 dark:hover:bg-zinc-800 dark:border-zinc-700" %>
              </div>
            <% end %>
          <% end %>
        </fieldset>
      </div>

    </div>
  </div>
</div>
